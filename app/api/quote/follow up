import { createClient } from '@supabase/supabase-js';
import { Resend } from 'resend';

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
);

const resend = new Resend(process.env.RESEND_API_KEY);

export async function GET(request: Request) {
  // Verify cron secret to prevent unauthorized calls
  const authHeader = request.headers.get('authorization');
  if (authHeader !== `Bearer ${process.env.CRON_SECRET}`) {
    return new Response('Unauthorized', { status: 401 });
  }

  // Find quotes submitted 48hrs ago that haven't been followed up
  const fortyEightHoursAgo = new Date(Date.now() - 48 * 60 * 60 * 1000);
  const fortyNineHoursAgo = new Date(Date.now() - 49 * 60 * 60 * 1000);

  const { data: quotes, error } = await supabase
    .from('quotes')
    .select('*')
    .eq('followed_up', false)
    .gte('created_at', fortyNineHoursAgo.toISOString())
    .lte('created_at', fortyEightHoursAgo.toISOString());

  if (error) {
    return Response.json({ error: error.message }, { status: 500 });
  }

  if (!quotes || quotes.length === 0) {
    return Response.json({ message: 'No quotes to follow up' });
  }

  const results = await Promise.all(
    quotes.map(async (quote) => {
      // Send follow-up email
      await resend.emails.send({
        from: 'Pylon Solar Services <quotes@pylonsolarservices.com>',
        to: quote.email,
        subject: 'Following up on your solar quote — Pylon Solar Services',
        html: `
          <div style="font-family: sans-serif; max-width: 600px; margin: 0 auto;">
            <h2>Hi ${quote.name},</h2>
            <p>We wanted to check in on the solar quote you requested a couple of days ago.</p>
            <p>We know it's a big decision, and we're here to help. If you have any questions about the process, pricing, or what's involved — we're happy to chat through it with you, no pressure at all.</p>
            <p>Just reply to this email or give us a call and we'll get back to you promptly.</p>
            <p>Thanks for considering Pylon Solar Services — we'd love to help you make the switch to solar.</p>
            <br />
            <p>Warm regards,<br /><strong>The Pylon Solar Services Team</strong></p>
            <p style="color: #888; font-size: 12px;">pylonsolarservices.com</p>
          </div>
        `,
      });

      // Mark as followed up
      await supabase
        .from('quotes')
        .update({ followed_up: true })
        .eq('id', quote.id);

      return quote.email;
    })
  );

  return Response.json({ message: `Followed up with ${results.length} quotes`, emails: results });
}